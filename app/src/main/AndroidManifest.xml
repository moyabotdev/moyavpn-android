<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!--
      Der VPN-Dienst selbst (android.net.VpnService) wird von der
      WireGuard-tunnel-Library (com.wireguard.android.backend.GoBackend$VpnService)
      bereitgestellt und automatisch ins Manifest gemerged. Wir muessen ihn hier
      nicht deklarieren. Beim Wechsel auf AmneziaWG bringt deren Library den
      entsprechenden Dienst mit.
    -->

    <application
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.MoyaVPN">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.MoyaVPN">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Deep Link: moyavpn://login?token=...  → App öffnet & loggt automatisch ein -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="moyavpn" android:host="login" />
            </intent-filter>

            <!-- App Link: https://app.moyabot.ru/i/...  (öffnet App direkt, sobald
                 assetlinks.json auf der Domain hinterlegt ist — sonst Auswahldialog) -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" android:host="app.moyabot.ru" android:pathPrefix="/i" />
            </intent-filter>
        </activity>

    </application>
</manifest>
